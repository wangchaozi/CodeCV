# ─── 应用 ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# 允许跨域的前端地址（多个用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ─── 数据库（PostgreSQL） ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=123456
DB_DATABASE=ai_resume_platform
# 生产环境必须设为 false，改用迁移文件
DB_SYNC=true
DB_LOGGING=false

# ─── JWT ─────────────────────────────────────────────────
# 生产环境必须替换为足够长的随机字符串
JWT_SECRET=replace_with_your_secure_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── 安全 ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ─── 文件上传 ─────────────────────────────────────────────
# 简历文件存储目录（绝对路径或相对于项目根目录的路径）
UPLOAD_DIR=uploads/resumes
